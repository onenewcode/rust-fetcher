# Live Room Configuration
live:
  # Required: Live room ID (e.g., "7319483754668557238")
  id: ""
  # Required: Business-specific Cookie
  cookie: ""

# IM Message Configuration
im:
  # Optional: Business-specific Cookie
  cookie: ""
  # Optional: Default Receiver ID
  receiver_id: ""
  # Optional: Default Message Content
  message_text: ""

# UI Theme Preference: light, dark, or blue (default: light)
theme: "light"

# Application Language (default: zh-CN)
language: "zh-CN"
